<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_customer_statement_button" model="ir.ui.view">
        <field name="name">res.partner.customer.statement</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="customer_rank" invisible="1"/>
                <button name="%(scopysoft_customer_statement.action_customer_statement_wizard)d"
                        string="Generate Statement"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        attrs="{'invisible': [('customer_rank', '=', 0)]}"/>
            </xpath>
        </field>
    </record>

</odoo>
