<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_customer_statement_wizard" model="ir.ui.view">
        <field name="name">customer.statement.wizard.form</field>
        <field name="model">customer.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Customer Statement">
                <group>
                    <group string="Customer">
                        <field name="partner_id"/>
                        <field name="company_id"/>
                    </group>
                    <group string="Options">
                        <field name="filter_type" widget="radio"/>
                    </group>
                </group>
                <group>
                    <group string="Date Range">
                        <field name="date_range"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_statement"
                            string="Print / Download PDF"
                            type="object"
                            class="btn-primary"
                            icon="fa-print"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
