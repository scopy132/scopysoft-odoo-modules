<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Cost Tracking button to Product Template -->
    <record id="product_template_form_view_inherit_cost_tracking" model="ir.ui.view">
        <field name="name">product.template.form.inherit.cost.tracking</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                    name="action_view_cost_tracking"
                    type="object"
                    icon="fa-line-chart"
                    invisible="cost_tracking_count == 0">
                    <field name="cost_tracking_count" widget="statinfo" string="Cost Changes" />
                </button>
            </xpath>
        </field>
    </record>

    <!-- Add Cost Tracking button to Product Variant -->
    <record id="product_product_form_view_inherit_cost_tracking" model="ir.ui.view">
        <field name="name">product.product.form.inherit.cost.tracking</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                    name="action_view_cost_tracking"
                    type="object"
                    icon="fa-line-chart"
                    invisible="cost_tracking_count == 0">
                    <field name="cost_tracking_count" widget="statinfo" string="Cost Changes" />
                </button>
            </xpath>
        </field>
    </record>

    <!-- Add Cost Tracking tab to Product Template -->
    <record id="product_template_form_view_inherit_cost_tracking_tab" model="ir.ui.view">
        <field name="name">product.template.form.inherit.cost.tracking.tab</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Cost History" name="cost_history"
                    invisible="cost_tracking_count == 0">
                    <field name="cost_tracking_ids" readonly="1">
                        <tree create="false" edit="false" delete="false">
                            <field name="create_date" string="Date" />
                            <field name="user_id" />
                            <field name="origin" />
                            <field name="old_cost" widget="monetary" />
                            <field name="new_cost" widget="monetary" />
                            <field name="cost_difference" widget="monetary"
                                decoration-success="cost_difference &gt; 0"
                                decoration-danger="cost_difference &lt; 0" />
                            <field name="cost_difference_percent"
                                decoration-success="cost_difference_percent &gt; 0"
                                decoration-danger="cost_difference_percent &lt; 0" />
                            <field name="currency_id" column_invisible="1" />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Add Cost Tracking tab to Product Variant -->
    <record id="product_product_form_view_inherit_cost_tracking_tab" model="ir.ui.view">
        <field name="name">product.product.form.inherit.cost.tracking.tab</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_variant_easy_edit_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='id']" position="after">
                <field name="cost_tracking_count" invisible="1" />
            </xpath>

            <xpath expr="//sheet" position="inside">
                <notebook invisible="cost_tracking_count == 0">
                    <page string="Cost History" name="cost_history">
                        <field name="cost_tracking_ids" readonly="1">
                            <tree create="false" edit="false" delete="false">
                                <field name="create_date" string="Date" />
                                <field name="user_id" />
                                <field name="origin" />
                                <field name="old_cost" widget="monetary" />
                                <field name="new_cost" widget="monetary" />
                                <field name="cost_difference" widget="monetary"
                                    decoration-success="cost_difference &gt; 0"
                                    decoration-danger="cost_difference &lt; 0" />
                                <field name="cost_difference_percent"
                                    decoration-success="cost_difference_percent &gt; 0"
                                    decoration-danger="cost_difference_percent &lt; 0" />
                                <field name="currency_id" column_invisible="1" />
                            </tree>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
