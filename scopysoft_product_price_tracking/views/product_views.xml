<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Price Tracking button to Product Template -->
    <record id="product_template_form_view_inherit_price_tracking" model="ir.ui.view">
        <field name="name">product.template.form.inherit.price.tracking</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                    name="action_view_price_tracking"
                    type="object"
                    icon="fa-tag"
                    invisible="price_tracking_count == 0">
                    <field name="price_tracking_count" widget="statinfo" string="Price Changes" />
                </button>
            </xpath>
        </field>
    </record>

    <!-- Add Price History tab to Product Template -->
    <record id="product_template_form_view_inherit_price_tracking_tab" model="ir.ui.view">
        <field name="name">product.template.form.inherit.price.tracking.tab</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Price History" name="price_history"
                    invisible="price_tracking_count == 0">
                    <field name="price_tracking_ids" readonly="1">
                        <tree create="false" edit="false" delete="false">
                            <field name="currency_id" column_invisible="1" />
                            <field name="create_date" string="Date" />
                            <field name="user_id" />
                            <field name="origin" />
                            <field name="old_price" widget="monetary" options="{'currency_field': 'currency_id'}" />
                            <field name="new_price" widget="monetary" options="{'currency_field': 'currency_id'}" />
                            <field name="price_difference" widget="monetary" options="{'currency_field': 'currency_id'}"
                                decoration-success="price_difference &gt; 0"
                                decoration-danger="price_difference &lt; 0" />
                            <field name="price_difference_percent"
                                decoration-success="price_difference_percent &gt; 0"
                                decoration-danger="price_difference_percent &lt; 0" />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
