<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add smart button to product template form -->
    <record id="view_product_template_vendor_price_history" model="ir.ui.view">
        <field name="name">product.template.vendor.price.history</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_vendor_price_history"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-history"
                        invisible="vendor_price_history_count == 0">
                    <field name="vendor_price_history_count" widget="statinfo" string="Price Changes"/>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Inline history tab on product form -->
    <record id="view_product_template_vendor_price_tab" model="ir.ui.view">
        <field name="name">product.template.vendor.price.tab</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Vendor Price History" invisible="vendor_price_history_count == 0">
                    <field name="vendor_price_history_ids" nolabel="1">
                        <tree string="Vendor Price History" decoration-danger="price_difference &lt; 0" decoration-success="price_difference &gt; 0">
                            <field name="currency_id" column_invisible="1"/>
                            <field name="create_date" string="Date"/>
                            <field name="partner_id" string="Vendor"/>
                            <field name="user_id" string="User"/>
                            <field name="old_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="new_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="price_difference" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="price_difference_percent" string="Diff (%)"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
